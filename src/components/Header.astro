---
// Header — sticky, logo izquierda, hamburguesa derecha que dispara el Drawer
// El botón hamburguesa tiene id="drawer-trigger"; el Drawer escucha ese id.
---
<header class="site-header">
  <div class="site-header-inner">
    <a href="/" class="site-logo" aria-label="Inicio — Observatorio del Sistema de Energía de Jalisco">
      Observatorio del Sistema de Energía de Jalisco
    </a>
    <button
      id="drawer-trigger"
      class="hamburger"
      type="button"
      aria-label="Abrir navegación"
      aria-expanded="false"
      aria-controls="site-drawer"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>
</header>
