---
// src/pages/sintesis/riesgos.astro
import Editorial from '../../layouts/Editorial.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import DisplayHeadline from '../../components/DisplayHeadline.astro';
import Subtitle from '../../components/Subtitle.astro';
import HairlineDivider from '../../components/HairlineDivider.astro';
import CrossRefText from '../../components/CrossRefText.tsx';
import CrossRef from '../../components/CrossRef.tsx';

import riesgosJson from '../../data/riesgos.json';
import crossRefsJson from '../../data/cross-references.json';

interface Riesgo {
  id: string;
  n: number;
  titulo: string;
  texto: string;
  reformas_vinculadas: string[];
  conflictos_vinculados: string[];
  vacios_vinculados: string[];
}

const riesgos = riesgosJson as Riesgo[];
const crossRefs = crossRefsJson as Record<string, any>;

const pageTitle = 'Riesgos críticos — Sección 4C';
const pageDescription =
  'Dos narrativas de riesgo que articulan la colisión entre el marco estatal de Jalisco y el marco federal energético post-marzo 2025.';
---

<Editorial title={pageTitle} description={pageDescription}>
  <article class="riesgos-page">
    <header class="riesgos-header">
      <Eyebrow>SÍNTESIS · SECCIÓN 4C</Eyebrow>
      <DisplayHeadline>
        Riesgos críticos
      </DisplayHeadline>
      <Subtitle>
        Dos narrativas que articulan la colisión entre el marco estatal de
        Jalisco y el marco federal energético post-marzo 2025.
      </Subtitle>
    </header>

    <HairlineDivider />

    {riesgos.map((r) => (
      <section class="riesgo-narrativa">
        <header class="narrativa-header">
          <span class="narrativa-id">{r.id}</span>
          <h2 class="narrativa-titulo">
            <CrossRefText client:load text={r.titulo} crossRefs={crossRefs} />
          </h2>
        </header>

        <div class="narrativa-texto">
          <CrossRefText client:load text={r.texto} crossRefs={crossRefs} />
        </div>

        <footer class="narrativa-vinculos">
          {r.reformas_vinculadas.length > 0 && (
            <div class="vinculo-grupo">
              <span class="vinculo-label">Reformas vinculadas</span>
              <span class="vinculo-codigos">
                {r.reformas_vinculadas.map((c) => (
                  <CrossRef client:load code={c} crossRefs={crossRefs} />
                ))}
              </span>
            </div>
          )}
          {r.conflictos_vinculados.length > 0 && (
            <div class="vinculo-grupo">
              <span class="vinculo-label">Conflictos vinculados</span>
              <span class="vinculo-codigos">
                {r.conflictos_vinculados.map((c) => (
                  <CrossRef client:load code={c} crossRefs={crossRefs} />
                ))}
              </span>
            </div>
          )}
          {r.vacios_vinculados.length > 0 && (
            <div class="vinculo-grupo">
              <span class="vinculo-label">Vacíos vinculados</span>
              <span class="vinculo-codigos">
                {r.vacios_vinculados.map((c) => (
                  <CrossRef client:load code={c} crossRefs={crossRefs} />
                ))}
              </span>
            </div>
          )}
        </footer>
      </section>
    ))}

    <div class="riesgos-watermark">
      Observatorio del Sistema de Energía de Jalisco · CC BY-NC-SA 4.0
    </div>
  </article>
</Editorial>

<style>
  .riesgos-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }
  .riesgos-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
    text-align: center;
    align-items: center;
  }
  .riesgo-narrativa {
    margin: 4rem 0;
    padding-top: 2rem;
    border-top: 1px solid var(--hair);
  }
  .riesgo-narrativa:first-of-type {
    border-top: none;
  }
  .narrativa-header {
    margin-bottom: 2rem;
  }
  .narrativa-id {
    display: block;
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--navy-soft);
    margin-bottom: 1rem;
  }
  .narrativa-titulo {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 300;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin: 0;
  }
  .narrativa-texto {
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-primary);
    text-align: justify;
    hyphens: auto;
  }
  .narrativa-vinculos {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--hair);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .vinculo-grupo {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 1.5rem;
    align-items: baseline;
  }
  .vinculo-label {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--navy-soft);
  }
  .vinculo-codigos {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .riesgos-watermark {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--hair);
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-align: center;
  }
  @media (max-width: 720px) {
    .riesgos-page {
      padding: 2rem 1rem 3rem;
    }
    .narrativa-titulo {
      font-size: 22px;
    }
    .narrativa-texto {
      font-size: 16px;
      text-align: left;
    }
    .vinculo-grupo {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
  }
</style>
