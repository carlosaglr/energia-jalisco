---
// src/pages/sintesis/proyectos/reforma-federal.astro
import Editorial from '../../../layouts/Editorial.astro';
import Eyebrow from '../../../components/Eyebrow.astro';
import DisplayHeadline from '../../../components/DisplayHeadline.astro';
import Subtitle from '../../../components/Subtitle.astro';
import HairlineDivider from '../../../components/HairlineDivider.astro';
import Explorer from '../../../components/Explorer.tsx';

import proyectosJson from '../../../data/proyectos-3c.json';
import ordenamientoMetaJson from '../../../data/ordenamiento-meta.json';
import crossRefsJson from '../../../data/cross-references.json';

interface Proyecto3C {
  id: string;
  seccion: string;
  n: number;
  titulo: string;
  reforma_federal_requerida: string;
  impacto: string;
  prioridad: 'Alta' | 'Media' | 'Baja';
}

const proyectos = proyectosJson as Proyecto3C[];

const ordenamientoMeta = ordenamientoMetaJson as Record<
  string,
  {
    tag: string;
    slug: string;
    ambito: 'federal' | 'estatal';
    nombre: { prefix: string; core: string; suffix: string };
    nombre_display: {
      prefix_italic: string;
      core_bold_italic: string;
      suffix_italic_small: string;
    };
  }
>;
const crossRefs = crossRefsJson as Record<string, any>;

// --- Metricas ---
const total = proyectos.length;
const alta = proyectos.filter((p) => p.prioridad === 'Alta').length;
const reformasReferidas = new Set(
  proyectos.map((p) => p.reforma_federal_requerida)
).size;
const impactosUnicos = new Set(proyectos.map((p) => p.impacto)).size;

const metrics = [
  { number: total, label: 'Proyectos con reforma federal' },
  { number: alta, label: 'Prioridad alta' },
  { number: reformasReferidas, label: 'Reformas federales requeridas' },
  { number: impactosUnicos, label: 'Tipos de impacto' },
];

// --- Config del Explorer ---
// Sin ord_estatal: distribucion agrupa por reforma_federal_requerida (mas informativo
// que prioridad, muestra que reformas federales desbloquean mas proyectos)
const config = {
  sectionCode: '3C',
  metrics,
  distribution: {
    groupBy: 'reforma_federal_requerida',
    stackBy: 'prioridad',
    stackOrder: ['Alta', 'Media', 'Baja'],
    colorMap: {
      Alta: 'var(--bar-alta)',
      Media: 'var(--bar-media)',
      Baja: 'var(--bar-baja)',
    },
    sortBy: 'count' as const,
    heading: 'Distribución por reforma federal requerida',
  },
  tabFilter: {
    field: 'prioridad',
    allLabel: 'Todas',
    options: ['Alta', 'Media', 'Baja'],
  },
  selectFilters: [
    { field: 'reforma_federal_requerida', label: 'Reforma federal' },
    { field: 'impacto', label: 'Impacto' },
  ],
  itemFields: {
    numero: 'n',
    ordTag: 'reforma_federal_requerida',
    tipo: 'impacto',
    texto: 'reforma_federal_requerida',
    articulo: '',
    prioridad: 'prioridad',
    titulo: 'titulo',
  },
};

const pageTitle = 'Proyectos viables con reforma federal — Sección 3C';
const pageDescription =
  'Quince proyectos ejecutivos cuya viabilidad depende de reformas al marco federal energético, fuera del control directo del estado de Jalisco.';
---

<Editorial title={pageTitle} description={pageDescription}>
  <article class="proyectos-page">
    <header class="proyectos-header">
      <Eyebrow>SÍNTESIS · SECCIÓN 3C</Eyebrow>
      <DisplayHeadline>
        Proyectos viables con reforma federal
      </DisplayHeadline>
      <Subtitle>
        Quince proyectos ejecutivos cuya viabilidad depende de reformas al marco
        federal energético, fuera del control directo del estado de Jalisco.
      </Subtitle>
    </header>

    <HairlineDivider />

    <Explorer
      client:load
      data={proyectos}
      config={config}
      ordenamientoMeta={ordenamientoMeta}
      crossRefs={crossRefs}
    />
  </article>
</Editorial>

<style>
  .proyectos-page {
    max-width: 1120px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }
  .proyectos-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  @media (max-width: 720px) {
    .proyectos-page {
      padding: 2rem 1rem 3rem;
    }
  }
</style>
